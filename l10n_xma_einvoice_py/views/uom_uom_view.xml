<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="inherit_view_id_inherit_uom_uom" model="ir.ui.view">
            <field name="name">uom.uom.view.form.inherit</field>
            <field name="model">uom.category</field>
            <field name="inherit_id" ref="uom.product_uom_categ_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//form//field[@name='name']" position="before">
                    <field name="country_id" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='uom_ids']//list/field[@name='uom_type']" position="before">
                    <field name="l10n_xma_uomcode_id" string="Código unidad de medida" column_invisible="parent.country_id != 185" groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_admin"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>