<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="inherit_view_id_inherit_acc_move_py" model="ir.ui.view">
            <field name="name">account.move.view.form.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <button name="send_to_matrix_json"
                        groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                        type="object" 
                        string="Timbrar" 
                        invisible="state != 'posted' or move_type not in ('out_invoice', 'out_refund', 'in_invoice') or is_einvoice_send == True or country_id != 185"
                        /> <!-- attrs="{'invisible':['|', '|', '|', ('state', '!=', 'posted'),('move_type', '!=', 'out_invoice'),('is_einvoice_send','=', True), ('country_id', '!=', 185)]}" -->
            </xpath>
                <xpath expr="//div[@name='journal_div']" position="after">
                    <field name="l10n_latam_document_type_id" 
                        groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user" 
                        domain="[['l10n_xma_transaction_type', 'in', ('','invoice')]]"
                        invisible="country_id != 185"
                    />
                    <!-- <field name="l10n_xma_date_post" options="{'datepicker': {'warn_future': true}}" 
                    invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt')"
                    groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"/> -->
                    <field name="l10n_xma_use_document_id" 
                        string="Tipo de Ingreso" 
                        groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                        domain="[('country_id', 'in', (False, country_id))]"
                        invisible="country_id != 185"
                    />
                    <field name="l10n_xma_origin_operation_id" 
                        string="Indicador de presencia" 
                        groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                        domain="[('country_id', 'in', (False, country_id))]"
                        invisible="country_id != 185"
                    />
                    <field name="l10n_xma_origin_operation_rel_code" invisible="1"/>
                    <field name="l10n_xma_descindpres" 
                        string="Descripcion para otros" 
                        groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                        invisible="country_id != 185 or l10n_xma_origin_operation_rel_code != '9'"
                    />
                    <field name="l10n_xma_issuance_type_id" 
                        string="Tipo de emisión" 
                        groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                        domain="[('country_id', 'in', (False, country_id))]"
                        invisible="country_id != 185"
                    />
                    <field name="l10n_xma_payment_form"
                        string="Tipo de pago" 
                        groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                        domain="[('country_id', 'in', (False, country_id))]"
                        invisible="country_id != 185"
                        required="0"
                    />
                    <field name="is_einvoice_send" invisible="1"/>
                    <field name="l10n_xma_edi_einvoice" 
                        string="Factura electronica" 
                        invisible="state == 'draft' or country_id != 185"
                        groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                    />
                    <field name="l10n_xma_uuid_invoice" readonly="1"
                    invisible="state == 'draft' or country_id != 185"
                    groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"/>
                    
                    <div class="o_row"
                        invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt') or country_id != 185">
                        <field name="l10n_xma_sifen_response"/>
                        <button name="consult_invoice_statur" type="object"
                                string="Consultar Factura" class="oe_link"
                                invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt') or country_id != 185"/>
                    </div>
                </xpath>
                <!-- <xpath  expr="//group[@id='header_right_group']/field[@name='invoice_date']" position="after" invisible="country_id != 185">
                    <field name="l10n_xma_date_post"  nolabel="1"
                        options="{'datepicker': {'warn_future': true}}" invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt')"
                        groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                    />
                </xpath> -->
                <xpath expr="//group[1]/group[1]" position="inside">
                    <field name="country_id" invisible="1"/>
                    <field name="l10n_xma_xml_ar"
                        invisible="state == 'draft' or country_id != 185"
                        readonly="1"
                        filename="l10n_xma_xml_name"
                        groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                    />
                    <field name="l10n_xma_xml_name" 
                        invisible="1" 
                        groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                    />
                    <field name="l10n_xma_document_type_rel" invisible="1"/>
                    <field name="debit_origin_id" readonly="0" invisible="(move_type not in ('out_refund','in_refund','out_invoice')) or (country_id != 185) or (l10n_xma_document_type_rel not in ('5', '6'))"/>

                    <field name="l10n_xma_motive_id"
                        invisible="(move_type not in ('out_refund','in_refund','out_invoice')) or (country_id != 185) or (l10n_xma_document_type_rel not in ('5', '6'))"
                        string="Motivo"
                        groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                    />
                    <field name="l10n_xma_tipo_doc_asociado" 
                        string="tipo de Documento Asociado"
                        invisible="(move_type not in ('out_refund','in_refund','out_invoice')) or (country_id != 185) or (l10n_xma_document_type_rel not in ('5', '6'))"
                        groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"      
                    />
                    <field name="l10n_xma_cdc_asociado"
                        string="cdc de Documento Asociado"
                        invisible="(move_type not in ('out_refund','in_refund','out_invoice')) or (country_id != 185) or (l10n_xma_document_type_rel not in ('5', '6'))"
                        groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                    />
                    <field name="l10n_xma_number_timbrado_asociado" 
                        string='Numero de timbrado'
                        invisible="(move_type not in ('out_refund','in_refund','out_invoice')) or (country_id != 185) or (l10n_xma_document_type_rel not in ('5', '6'))"
                    groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                    />
                    <field name="l10n_xma_cod_state_asociado" 
                        invisible="(move_type not in ('out_refund','in_refund','out_invoice')) or (country_id != 185) or (l10n_xma_document_type_rel not in ('5', '6'))"
                    groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                    />
                    <field name="l10n_xma_point_exp_asociado" 
                        invisible="(move_type not in ('out_refund','in_refund','out_invoice')) or (country_id != 185) or (l10n_xma_document_type_rel not in ('5', '6'))"
                    groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                    />
                    <field name="l10n_xma_document_number_asociado" 
                        invisible="(move_type not in ('out_refund','in_refund','out_invoice')) or (country_id != 185) or (l10n_xma_document_type_rel not in ('5', '6'))"
                    groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                    />
                    <field name="l10n_document_type_asociado" 
                        invisible="(move_type not in ('out_refund','in_refund','out_invoice')) or (country_id != 185) or (l10n_xma_document_type_rel not in ('5', '6'))"
                    groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                    />
                    <field name="l10n_xma_date_document_emision" 
                        invisible="(move_type not in ('out_refund','in_refund','out_invoice')) or (country_id != 185) or (l10n_xma_document_type_rel not in ('5', '6'))"
                        groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                    />
                    <field name="l10n_xma_payment_condition" 
                        string="Condicion de pago"
                        groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                        invisible="country_id != 185 or l10n_xma_payment_term != 'credit'"
                    />
                    <field name="l10n_xma_number_subscription"
                        string="Numero de Coutas"
                        groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                        invisible="country_id != 185 or l10n_xma_payment_term != 'credit'"
                    />
                    <field name="l10n_xma_payment_term"
                        string="Termino de pago"
                        groups="l10n_xma_einvoice_py.l10n_xma_invoice_py_user"
                        invisible="country_id != 185"
                    />
                </xpath>
                <xpath expr="//notebook" position="inside">
                    <field name="l10n_xma_payment_form_code" invisible="1"/>
                    <page string="Datos tarjeta" invisible="l10n_xma_payment_form_code not in ('3', '4')">
                        <group>
                            <group>
                                <field name="l10n_xma_card_type_id" required="l10n_xma_payment_form_code in ('3', '4')"/>
                                <field name="l10n_xma_authorization_code" required="l10n_xma_payment_form_code in ('3', '4')"/>
                                <field name="l10n_xma_cardholder_name" required="l10n_xma_payment_form_code in ('3', '4')"/>
                                <field name="l10n_xma_digit_card"/>

                            </group>
                            <group>
                                <field name="l10n_xma_bank_name"/>
                                <field name="l10n_xma_vat_bank"/>
                                <field name="l10n_xma_procces_payment_type"/>
                            </group>
                        </group>
                    </page>
                    <page string="Datos cheque" invisible="l10n_xma_payment_form_code != '2' ">
                        <group>
                            <field name="l10n_xma_digit_card" string="Numero de Cheque"/>
                            <field name="l10n_xma_bank_name" string="Banco Emisor"/>
                        </group>
                    </page>
                </xpath>
                <xpath expr="//div[@name='button_box']" position="inside">
                    <field name="l10n_xma_compute_debit_count" invisible="1"/>
                    <field name="l10n_xma_compute_credit_count" invisible="1"/>
                    <button name="l10n_xma_action_view_debit_notes"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-pencil-square-o"
                            invisible="l10n_xma_compute_debit_count == 0">
                        <field name="l10n_xma_compute_debit_count" widget="statinfo"
                                string="Notas de Débito"/>
                    </button>
                    <button type="object" class="oe_stat_button" name="l10n_xma_action_view_credit_notes" icon="fa-plus" invisible="l10n_xma_compute_credit_count == 0">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_value"><field name="l10n_xma_compute_credit_count"/></span>
                            <span class="o_stat_text">Notas de Crédito</span>
                        </div>
                    </button>
                </xpath>
                <!--button name="cancel" position="before">
                    <button string="" name="l10n_xma_einvoice_send" type="object" class="oe_highlight"/>
                </button-->
                
            </field>
        </record>
        <record id="l10n_latam_invoice_document_view_move_form_inherit" model="ir.ui.view">
            <field name="name">l10n_latam_invoice_document.view_move_form.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="l10n_latam_invoice_document.view_move_form" />
            <field name="arch" type="xml">
                <xpath expr="//field[@name='l10n_latam_document_type_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>
        
    </data>
</odoo>
